<Window x:Class="BplmSw.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RMS 登录" Height="240" Width="330" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Username -->
        <Label Grid.Row="0" Grid.Column="0" Content="账号:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtUsername" Grid.Row="0" Grid.Column="1" Margin="5,0,5,5" VerticalAlignment="Bottom"/>

        <!-- Password -->
        <Label Grid.Row="1" Grid.Column="0" Content="密码:" VerticalAlignment="Center"/>
        <Grid Grid.Row="1" Grid.Column="1" Margin="5">
            <PasswordBox x:Name="txtPassword" VerticalAlignment="Center"/>
            <TextBox x:Name="txtPasswordVisible" Visibility="Collapsed" VerticalAlignment="Center"/>
        </Grid>

        <!-- Options -->
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <CheckBox x:Name="chkShowPassword" Content="显示密码" Margin="0,0,15,0" Checked="chkShowPassword_Checked" Unchecked="chkShowPassword_Unchecked"/>
            <CheckBox x:Name="chkRememberPassword" Content="记住密码"/>
        </StackPanel>

        <!-- Server -->
        <Label Grid.Row="3" Grid.Column="0" Content="服务器：" VerticalAlignment="Center"/>
        <TextBlock x:Name="ServerEnvironmentTextBlock" 
           Text="" 
           Grid.Row="3" 
           Grid.Column="1"
           VerticalAlignment="Center"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
            <Button x:Name="btnLogin" Content="登录" Width="80" Margin="10" Click="btnLogin_Click"/>
            <Button x:Name="btnCancel" Content="取消" Width="80" Margin="10" Click="btnCancel_Click"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock x:Name="lblStatus" Grid.Row="5" Grid.ColumnSpan="2" Foreground="Red" HorizontalAlignment="Center" VerticalAlignment="Bottom" />
    </Grid>
</Window>