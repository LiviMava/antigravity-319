<UserControl x:Class="BplmSw.NewDoc.FolderUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BplmSw.NewDoc"
             mc:Ignorable="d" 
             d:DesignHeight="350" d:DesignWidth="400">
    <UserControl.Resources>
        <!-- 工具提示样式 -->
        <Style x:Key="TreeItemToolTipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#FFF0F0F0"/>
            <Setter Property="BorderBrush" Value="#FF808080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="HasDropShadow" Value="True"/>
        </Style>

        <!-- 复杂ToolTip的数据模板 -->
        <DataTemplate x:Key="ComplexToolTipTemplate">
            <StackPanel Margin="4" MaxWidth="300">
                <!-- 标题 -->
                <TextBlock Text="{Binding Name}" 
                       FontWeight="Bold" 
                       FontSize="10"
                       Foreground="#FF333333"
                       Margin="0,0,0,4"/>

                <!-- 分隔线 -->
                <Border Height="1" Background="#FFCCCCCC" Margin="0,4,0,6"/>

                <!-- 详细信息 -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="20"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="拥有者:" Foreground="#FF666666"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Ownner}" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="签入签出状态:" Foreground="#FF666666"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CheckInOutStatus}" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="类型:" Foreground="#FF666666"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ObjectType}" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <Label Content="已选择:" Height="25" Width="45" FontSize="10" VerticalAlignment="Center"/>
            <TextBox x:Name="curFolder" Height="20" Width="150" FontSize="10" FontWeight="Bold" IsEnabled="False"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1">
            <Label Content="名称" Height="25" Width="30" FontSize="10" VerticalAlignment="Center"/>
            <TextBox x:Name="textName" Height="20" Width="100" FontSize="10" Margin="10, 0, 0, 0"/>
            <Label Content="所有人" Height="25" Width="40" FontSize="10" VerticalAlignment="Center"/>
            <TextBox x:Name="textOwnner" Height="20" Width="100" FontSize="10" Margin="10, 0, 0, 0"/>
            <Button x:Name="btnSearch" Height="15" Width="30" FontSize="9" Content="搜索" Margin="10, 0, 0, 0" Click="btnSearch_Click"/>
            <Button x:Name="btnBack" Height="15" Width="30" FontSize="9" Content="回退" Margin="10, 0, 0, 0" Click="btnBack_Click"/>
        </StackPanel>

        <TreeView x:Name="treeViewFolder" ItemsSource="{Binding RootFolders}" MouseDoubleClick="TreeView_MouseDoubleClick" Grid.Row="2" Background="#FFE5E5E5">
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="刷新" Click="RefreshMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="新建文件夹" Click="AddChildMenuItem_Click"/>
                    <MenuItem Header="重命名" Click="RenameMenuItem_Click"/>
                    <MenuItem Header="删除" Click="DeleteMenuItem_Click"/>
                </ContextMenu>
            </TreeView.ContextMenu>

            <!-- TreeView样式 -->
            <TreeView.Resources>
                <Style TargetType="TreeViewItem" x:Key="TreeViewItemHoverStyle">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <!--<Setter Property="Padding" Value="4,2"/>
                    <Setter Property="Margin" Value="0,1"/>-->
                    <Setter Property="IsExpanded" Value="true"/>

                    <Style.Triggers>
                        <!-- 鼠标悬停效果 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F0F8FF"/>
                            <Setter Property="BorderBrush" Value="#C0D8FF"/>
                            <Setter Property="Foreground" Value="#0066CC"/>
                        </Trigger>

                        <!-- 选中效果 -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E3F2FD"/>
                            <Setter Property="BorderBrush" Value="#64B5F6"/>
                            <Setter Property="Foreground" Value="#1565C0"/>
                        </Trigger>

                        <!-- 悬停+选中组合效果 -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="#BBDEFB"/>
                            <Setter Property="BorderBrush" Value="#2196F3"/>
                        </MultiTrigger>

                        <!-- 焦点效果 -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="#2196F3"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.Resources>

            <TreeView.ItemContainerStyle>
                <StaticResource ResourceKey="TreeViewItemHoverStyle"/>
            </TreeView.ItemContainerStyle>


            <!-- TreeView的数据模板 -->
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type local:FolderItem}" ItemsSource="{Binding SubItems}">
                    <Grid>
                        <StackPanel x:Name="displayPanel" Orientation="Horizontal">
                            <Image Source="Resources/folder.png" Width="16" Height="16"/>
                            <TextBlock Text="{Binding Name}" Margin="5,0,0,0">
                                <TextBlock.ToolTip>
                                    <ToolTip Style="{StaticResource TreeItemToolTipStyle}"
                                 Content="{Binding}"
                                 ContentTemplate="{StaticResource ComplexToolTipTemplate}"/>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel x:Name="editPanel" Orientation="Horizontal">
                            <Image Source="Resources/folder.png" Width="16" Height="16"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="5,0,0,0" KeyDown="EditTextBox_KeyDown" LostFocus="TextBox_LostFocus" Loaded="TextBox_Loaded">
                                <TextBox.ToolTip>
                                    <ToolTip Style="{StaticResource TreeItemToolTipStyle}"
                                 Content="{Binding}"
                                 ContentTemplate="{StaticResource ComplexToolTipTemplate}"/>
                                </TextBox.ToolTip>
                            </TextBox>
                        </StackPanel>
                    </Grid>

                    <HierarchicalDataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                            <Setter TargetName="displayPanel" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="editPanel" Property="Visibility" Value="Visible"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding IsEditing}" Value="False">
                            <Setter TargetName="displayPanel" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="editPanel" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </HierarchicalDataTemplate.Triggers>
                </HierarchicalDataTemplate>

            </TreeView.ItemTemplate>
        </TreeView>

        <DataGrid Grid.Row="2" x:Name="dataGridSearch" AutoGenerateColumns="False" HeadersVisibility="Column"
                                  HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray" BorderBrush="Gray" BorderThickness="1"
                                 ItemsSource="{Binding SearchFolders}" Visibility="Collapsed"
                                  CanUserAddRows="False" MouseDoubleClick="dataGridSearch_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名称" Width="*" Binding="{Binding Name}" IsReadOnly="True"/>
                <DataGridTextColumn Header="类型" Width="*" Binding="{Binding ObjectType}" IsReadOnly="True"/>
                <DataGridTextColumn Header="所有者" Width="*" Binding="{Binding Ownner}" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>