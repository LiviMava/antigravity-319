<Window x:Class="BplmSw.NewDoc.NewDocWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BplmSw.NewDoc"
        mc:Ignorable="d"
        Title="新建" Height="600" Width="800"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary Source="pack://application:,,,/BplmSw.NewDoc;component/Themes/Generic.xaml"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Expander Header="模板" Style="{StaticResource TaskPane_ExpanderStyle}" IsExpanded="True" Grid.Column="0">
                <DataGrid x:Name="dataGridTemplate" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                          HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray" BorderBrush="Gray" BorderThickness="1"
                          Margin="10" SelectionChanged="DataGridTemplate_SelectionChanged" CanUserAddRows="False" ItemsSource="{Binding TemplateItems}"
                          RowStyle="{StaticResource SimpleRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Width="*" Binding="{Binding Name}"/>
                        <DataGridTextColumn Header="类型" Width="*" Binding="{Binding Suffix}"/>
                        <DataGridTextColumn Header="单位" Width="*" Binding="{Binding Unit}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Expander>

            <Expander Header="预览" Style="{StaticResource TaskPane_ExpanderStyle}" IsExpanded="True" Grid.Column="1" >
                <Image x:Name="imgPreview" Source="Resources/preview.bmp" Stretch="Uniform" Margin="10"/>
            </Expander>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Expander Header="属性" Style="{StaticResource TaskPane_ExpanderStyle}" IsExpanded="True">
                    <Grid Background="#FFE5E5E5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="25"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <StackPanel Orientation="Horizontal" >
                                <Label Content="项类型" Height="25" Width="40" FontSize="10" VerticalAlignment="Center"/>
                                <ComboBox x:Name="comboBoxItemType" Height="20" Width="80" FontSize="10" VerticalAlignment="Center"
                                          HorizontalAlignment="Center" SelectionChanged="ComboBoxItemType_SelectionChanged"/>
                            </StackPanel>
                            <Button x:Name="btnAttr" Height="20" Width="80" Content="次要属性" HorizontalAlignment="Right" Click="btnAttr_Click"/>
                        </Grid>

                        <DataGrid Grid.Row="1" x:Name="dataGridInfo" AutoGenerateColumns="False" HeadersVisibility="Column"
                                  HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray" BorderBrush="Gray" BorderThickness="1"
                                  Margin="10" ItemsSource="{Binding RequiredAttrItems}" BeginningEdit="dataGridInfo_BeginningEdit"
                                  CanUserAddRows="False" ContextMenuOpening="dataGridInfo_ContextMenuOpening" CellEditEnding="dataGridInfo_CellEditEnding"
                                  RowStyle="{StaticResource SimpleRowStyle}" PreviewMouseLeftButtonDown="dataGridInfo_PreviewMouseLeftButtonDown">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRequired}" Value="True">
                                            <Setter Property="FontWeight" Value="Bold" />
                                            <Setter Property="ToolTip" Value="必填" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="名称" Width="*" Binding="{Binding Description}" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="值" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0" Text="{Binding Value, ValidatesOnDataErrors=True}"/>
                                                <Button Grid.Column="1" Content="指派" x:Name="btnAssign" FontSize="10" FontWeight="Bold" Click="btnAssign_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Mode}" Value="assign">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Mode}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Expander>
            </Grid>

            <Grid Grid.Column="1">
                <Grid>
                    <Expander x:Name="expFolder" Header="文件夹"  Style="{StaticResource TaskPane_ExpanderStyle}" IsExpanded="True">
                        <local:FolderUserControl x:Name="folderSelector" DataPassed ="FolderWindow_DataPassed"/>
                    </Expander>
                </Grid>
            </Grid>
        </Grid>

        <Expander x:Name="expRefItem" Header="参考零部件"  Style="{StaticResource TaskPane_ExpanderStyle}" IsExpanded="True" Grid.Row="2">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Label Content="编码" Height="25" Width="40" FontSize="10"/>
                    <TextBox x:Name="txtRefItemId" Height="20" Width="90" FontSize="10" IsEnabled="False"/>
                    <Label Content="版本" Height="25" Width="40" FontSize="10"/>
                    <TextBox x:Name="txtRefItemRevId" Height="20" Width="90" FontSize="10" IsEnabled="False"/>
                    <Label Content="名称" Height="25" Width="40" FontSize="10"/>
                    <TextBox x:Name="txtRefObjectName" Height="20" Width="90" FontSize="10" IsEnabled="False"/>
                </StackPanel>
                <Button x:Name="btnBrowse" Content="浏览" Height="20" Width="60" FontSize="10" HorizontalAlignment="Right" Margin="0, 0, 20 0" Click="btnBrowse_Click"/>
            </Grid>
        </Expander>


        <Grid Grid.Row="3">
            <Button x:Name="btnConfirm" Content="确定" Width="80" Height="25" Margin="0, 10, 150, 10" HorizontalAlignment="Right" Click="btnConfirm_Click"
                                IsEnabled="{Binding IsBtnConfirmEnable}"/>
            <Button x:Name="btnCancel" Content="取消" Width="80" Height="25" Margin="0, 10, 50, 10" HorizontalAlignment="Right" Click="btnCancel_Click"/>
        </Grid>
    </Grid>

</Window>