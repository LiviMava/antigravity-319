<Window x:Class="BplmSw.NewDoc.AttrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BplmSw.NewDoc"
        mc:Ignorable="d"
        Title="次要属性" Height="400" Width="400"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="dataGridAttr" AutoGenerateColumns="False" IsReadOnly="False" HeadersVisibility="Column"
         HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray" BorderBrush="Gray"
         BorderThickness="1" Margin="10" Background="#FFE5E5E5" CanUserAddRows="False" ItemsSource="{Binding AttrItems}"
         BeginningEdit="dataGridAttr_BeginningEdit">

            <DataGrid.Resources>
                <Style TargetType="DataGridCell">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRequired}" Value="True">
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="ToolTip" Value="必填" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                            <Setter Property="FontStyle" Value="Italic"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="标题" Width="2*" Binding="{Binding Description}" IsReadOnly="True"/>
                <DataGridTextColumn Header="值" Width="2*" Binding="{Binding Value, ValidatesOnDataErrors=True}" IsReadOnly="False"/>
                <DataGridTextColumn Header="类型" Width="*" Binding="{Binding Type, FallbackValue='字符串'}" IsReadOnly="True"/>
                <DataGridTextColumn Header="只读" Width="*" Binding="{Binding IsReadOnly}" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Button x:Name="btnConfirm" Content="确定" Width="80" Height="25" Margin="0, 10, 150, 10" HorizontalAlignment="Right" Click="btnConfirm_Click"/>
            <Button x:Name="btnCancel" Content="取消" Width="80" Height="25" Margin="0, 10, 50, 10" HorizontalAlignment="Right" Click="btnCancel_Click"/>
        </Grid>

    </Grid>
</Window>